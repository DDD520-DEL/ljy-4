generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Pet {
  id           String     @id @default(uuid())
  name         String
  species      String     // dog, cat, etc.
  breed        String?
  gender       String     // male, female, unknown
  birthDate    DateTime?
  color        String?
  weight       Float?
  description  String?
  avatarUrl    String?
  isBreeding   Boolean    @default(false)
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  parentRelations  ParentRelation[] @relation("PetParentChild")
  childRelations   ParentRelation[] @relation("PetChildParent")
  geneReports      GeneReport[]
  geneMarkers      GeneMarkerData[]
  ownedBy          String?

  breedingPairsAsMale   BreedingPair[] @relation("BreedingMale")
  breedingPairsAsFemale BreedingPair[] @relation("BreedingFemale")
  riskPredictions       RiskPrediction[]
  weightRecords         WeightRecord[]
  puppyRecords          PuppyRecord[]
  transferRecords       PetTransfer[]
  breedingAlerts        BreedingAlert[]
  geneTestAppointments  GeneTestAppointment[]
}

model ParentRelation {
  id        String   @id @default(uuid())
  parentId  String
  childId   String
  relationType String // father, mother

  parent    Pet      @relation("PetParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  child     Pet      @relation("PetChildParent", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId, relationType])
}

model GeneReport {
  id                String              @id @default(uuid())
  petId             String
  reportType        String              // pdf, image
  fileName          String
  fileUrl           String?
  parsedData        String?
  status            String              @default("pending") // pending, parsed, failed
  uploadedAt        DateTime            @default(now())
  parsedAt          DateTime?
  appointmentId     String?

  pet               Pet                 @relation(fields: [petId], references: [id], onDelete: Cascade)
  geneTestAppointment GeneTestAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
}

model GeneticMarker {
  id            String   @id @default(uuid())
  markerName    String
  geneName      String
  chromosome    String?
  position      Int?
  variant       String
  disease       String
  species       String
  inheritance   String   // autosomal_dominant, autosomal_recessive, x_linked, etc.
  riskLevel     String   // high, medium, low
  description   String?
  reference     String?
  createdAt     DateTime @default(now())

  markerData    GeneMarkerData[]
}

model GeneMarkerData {
  id           String   @id @default(uuid())
  petId        String
  markerId     String
  genotype     String   // AA, Aa, aa, etc.
  allele1      String?
  allele2      String?
  zygosity     String?  // homozygous, heterozygous, hemizygous
  source       String?  // test_report, imputed, predicted
  testedAt     DateTime?

  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  marker       GeneticMarker @relation(fields: [markerId], references: [id], onDelete: Cascade)

  @@unique([petId, markerId])
}

model RiskPrediction {
  id              String   @id @default(uuid())
  petId           String
  disease         String
  riskScore       Float
  riskLevel       String   // low, medium, high
  predictionType  String   // individual, offspring
  parent1Id       String?
  parent2Id       String?
  details         String?
  createdAt       DateTime @default(now())

  pet             Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model BreedingPair {
  id         String   @id @default(uuid())
  maleId     String
  femaleId   String
  name       String?
  notes      String?
  inbreedingCoefficient Float?
  riskAssessment String?
  status     String   @default("active")
  createdAt  DateTime @default(now())

  male       Pet      @relation("BreedingMale", fields: [maleId], references: [id])
  female     Pet      @relation("BreedingFemale", fields: [femaleId], references: [id])

  litterRecords LitterRecord[]
}

model WeightRecord {
  id          String   @id @default(uuid())
  petId       String
  weight      Float
  recordedAt  DateTime @default(now())
  note        String?
  createdAt   DateTime @default(now())

  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model LitterRecord {
  id              String   @id @default(uuid())
  breedingPairId  String
  birthDate       DateTime
  totalCount      Int
  aliveCount      Int
  deadCount       Int
  notes           String?
  healthComparison String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  breedingPair    BreedingPair @relation(fields: [breedingPairId], references: [id], onDelete: Cascade)
  puppies         PuppyRecord[]
}

model PuppyRecord {
  id              String   @id @default(uuid())
  litterRecordId  String
  petId           String?
  name            String?
  gender          String
  birthWeight     Float?
  color           String?
  status          String   @default("alive")
  healthStatus    String   @default("normal")
  healthNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  litterRecord    LitterRecord @relation(fields: [litterRecordId], references: [id], onDelete: Cascade)
  pet             Pet?         @relation(fields: [petId], references: [id], onDelete: SetNull)
}

model PetTransfer {
  id              String   @id @default(uuid())
  petId           String
  fromOwnerName   String
  fromOwnerContact String?
  toOwnerName     String
  toOwnerContact  String?
  transferDate    DateTime
  notes           String?
  createdAt       DateTime @default(now())

  pet             Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model BreedingAlert {
  id          String   @id @default(uuid())
  petId       String?
  alertType   String   // inbreeding_threshold, genetic_high_risk
  severity    String   // warning, danger
  title       String
  message     String
  details     String?  // JSON string
  isRead      Boolean  @default(false)
  sourceId    String?  // 关联的源ID，如markerId或breedingPairId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pet         Pet?     @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([petId])
  @@index([alertType])
}

model GeneTestAppointment {
  id               String        @id @default(uuid())
  petId            String
  institution      String      // 检测机构名称
  expectedDate     DateTime    // 预计检测日期
  testItems        String      // 检测项目（逗号分隔的字符串或JSON）
  status           String      @default("pending") // pending, confirmed, testing, completed, cancelled
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  completedAt      DateTime?

  pet              Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  geneReports      GeneReport[]

  @@index([petId])
  @@index([status])
}
